# Stage 1: Build the frontend
FROM node:lts-alpine3.22 AS frontend-build

# Define build arguments
ARG OKTA_ISSUER
ARG NEXTAUTH_URL
ARG REDIRECT_LINK
ARG NEXT_PUBLIC_DOCS_PATH
ARG NEXT_PUBLIC_API_URL
ARG OKTA_CLIENT_ID
ARG OKTA_CLIENT_SECRET
ARG NEXTAUTH_SECRET
ARG BACKEND_BASE_URL
ARG NEXT_PUBLIC_DISABLE_FRONTEND_AUTHENTICATION
ARG AUTH_TRUST_HOST

# Set environment variables
ENV OKTA_ISSUER=${OKTA_ISSUER}
ENV NEXTAUTH_URL=${NEXTAUTH_URL}
ENV REDIRECT_LINK=${REDIRECT_LINK}
ENV NEXT_PUBLIC_DOCS_PATH=${NEXT_PUBLIC_DOCS_PATH}
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV OKTA_CLIENT_ID=${OKTA_CLIENT_ID}
ENV OKTA_CLIENT_SECRET=${OKTA_CLIENT_SECRET}
ENV NEXTAUTH_SECRET=${NEXTAUTH_SECRET}
ENV BACKEND_BASE_URL=${BACKEND_BASE_URL}
ENV AUTH_TRUST_HOST=${AUTH_TRUST_HOST}
ENV NEXT_PUBLIC_DISABLE_FRONTEND_AUTHENTICATION=${NEXT_PUBLIC_DISABLE_FRONTEND_AUTHENTICATION}

# Set working directory
WORKDIR /usr/src/app

# Configure INL certs and environment variables
RUN apk --no-check-certificate add ca-certificates
COPY CAINLROOT_B64.crt /usr/local/share/ca-certificates/CAINLROOT_B64.crt
RUN /usr/sbin/update-ca-certificates
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt
ENV REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
ENV CURL_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
ENV SSL_CERT_DIR=/etc/ssl/certs/

# Install latest global npm version and packages
RUN npm install -g npm@latest

# Copy package.json first
COPY deeplynx.UI/package*.json ./

# Install frontend dependencies
RUN npm install

# Copy the rest of the frontend source code
COPY deeplynx.UI .

# Build the frontend
RUN npm run build

# Stage 2: Create the final image
FROM node:lts-alpine3.22 AS final

# Set working directory
WORKDIR /usr/src/app

# Configure INL certs and environment variables
RUN apk --no-check-certificate add ca-certificates
COPY CAINLROOT_B64.crt /usr/local/share/ca-certificates/CAINLROOT_B64.crt
RUN /usr/sbin/update-ca-certificates
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt
ENV REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
ENV CURL_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
ENV SSL_CERT_DIR=/etc/ssl/certs/

# Install latest global npm version and packages
RUN npm install -g npm@latest

# Copy the built frontend code from the previous stage
COPY --from=frontend-build /usr/src/app .

# Install all dependencies (including dev dependencies for TypeScript support)
RUN npm install

# Expose the port the app runs on
EXPOSE 3000

# Set the command to run the application
CMD ["npm", "start"]
