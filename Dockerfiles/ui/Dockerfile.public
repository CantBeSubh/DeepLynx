# Stage 1: Build the frontend
FROM node:lts-alpine3.22 AS frontend-build

# Define build arguments
ARG OKTA_CLIENT_ID
ARG OKTA_ISSUER
ARG REDIRECT_LINK
ARG OKTA_CLIENT_SECRET
ARG AUTH_SECRET
ARG NEXTAUTH_SECRET
ARG SERVICE_TOKEN
ARG BACKEND_BASE_URL
ARG NEXTAUTH_URL
ARG NEXT_PUBLIC_DISABLE_FRONTEND_AUTHENTICATION

# Set environment variables
ENV OKTA_CLIENT_ID=${OKTA_CLIENT_ID}
ENV OKTA_ISSUER=${OKTA_ISSUER}
ENV REDIRECT_LINK=${REDIRECT_LINK}
ENV OKTA_CLIENT_SECRET=${OKTA_CLIENT_SECRET}
ENV AUTH_SECRET=${AUTH_SECRET}
ENV NEXTAUTH_SECRET=${NEXTAUTH_SECRET}
ENV SERVICE_TOKEN=${SERVICE_TOKEN}
ENV BACKEND_BASE_URL=${BACKEND_BASE_URL}
ENV NEXTAUTH_URL=${NEXTAUTH_URL}
ENV NEXT_PUBLIC_DISABLE_FRONTEND_AUTHENTICATION=${NEXT_PUBLIC_DISABLE_FRONTEND_AUTHENTICATION}

# # Print out the value of the environment variables
# RUN echo "OKTA_CLIENT_ID=${OKTA_CLIENT_ID}" \
#     && echo "OKTA_ISSUER=${OKTA_ISSUER}" \
#     && echo "REDIRECT_LINK=${REDIRECT_LINK}" \
#     && echo "OKTA_CLIENT_SECRET=${OKTA_CLIENT_SECRET}" \
#     && echo "AUTH_SECRET=${AUTH_SECRET}" \
#     && echo "NEXTAUTH_SECRET=${NEXTAUTH_SECRET}" \
#     && echo "BACKEND_BASE_URL=${BACKEND_BASE_URL}" \
#     && echo "NEXT_PUBLIC_DISABLE_FRONTEND_AUTHENTICATION=${NEXT_PUBLIC_DISABLE_FRONTEND_AUTHENTICATION}" \
#     && echo "NEXTAUTH_URL=${NEXTAUTH_URL}"

# Set working directory
WORKDIR /usr/src/app

# Install versioned os packages
# RUN apk update && apk upgrade --no-cache && \
#     apk add --no-cache \
#       openssl=3.3.5-r0 \
#       busybox=1.36.1-r31

# Install latest npm version and packages
RUN npm install -g npm@latest

# Copy package.json and package-lock.json first
COPY deeplynx.UI/package*.json ./

# Install frontend dependencies
RUN npm install

# Copy the rest of the frontend source code
COPY deeplynx.UI .

# Build the frontend
RUN npm run build

# Stage 2: Create the final image
FROM node:lts-alpine3.22 AS final

# Install versioned os packages
# RUN apk update && apk upgrade --no-cache && \
#     apk add --no-cache \
#       openssl=3.3.5-r0 \
#       busybox=1.36.1-r31

# Set working directory
WORKDIR /usr/src/app

# Copy package files first
COPY --from=frontend-build /usr/src/app/package*.json ./

# Install latest npm version and packages
RUN npm install -g npm@latest

# Install production dependencies BEFORE copying build artifacts
RUN npm install --omit-dev

# NOW copy the built application (including .next folder)
COPY --from=frontend-build /usr/src/app/.next ./.next
COPY --from=frontend-build /usr/src/app/public ./public
# COPY --from=frontend-build /usr/src/app/next.config.js ./next.config.js

# Expose the port the app runs on
EXPOSE 3000

# Set the command to run the application
CMD ["npm", "start"]