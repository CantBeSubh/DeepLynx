# ================================ 
# FRONTEND DEVELOPMENT
# ================================
# developers- please contact someone on the UI team for the auth/okta credentials

# --------------------------------
# Public (safe for browser)
# --------------------------------
OKTA_ISSUER="https://identity-preview.inl.gov"
NEXTAUTH_URL="http://localhost:3000"
REDIRECT_LINK="http://localhost:3000/api/auth/callback/okta"

# these are only used locally, not in deployed environments
NEXT_PUBLIC_DOCS_PATH="http://localhost:3001/docs"
NEXT_PUBLIC_API_URL="http://localhost:5095/api"

# --------------------------------
# Server-only (never expose to browser)
# --------------------------------
OKTA_CLIENT_ID=""
OKTA_CLIENT_SECRET=""
NEXTAUTH_SECRET=""

# --------------------------------
# Use this for build-time/server fetches
# --------------------------------
BACKEND_BASE_URL="http://localhost:5095/api"
SERVICE_TOKEN=""
NEXTAUTH_DEBUG=true

# --------------------------------
# Local Development
# --------------------------------
DISABLE_FRONTEND_AUTHENTICATION=false

# ================================
# Vital non-code environment variables
# ================================
AUTH_TRUST_HOST=true
# these variables are not defined anywhere in the codebase, but are essential
# to run the application. Do not delete them from the kubernetes and docker files.
# DATABASE_CONNECTION_STRING
# NEXTAUTH_DEBUG
# NEXTAUTH_URL
# NEXTAUTH_SECRET